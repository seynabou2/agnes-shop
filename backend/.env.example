# ── En local : copie ce fichier en .env et remplis les valeurs ──
# ── Sur Render.com : colle ces variables dans "Environment" ──────

# Base de données PostgreSQL
# En local :
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boutique_agnes
DB_USER=postgres
DB_PASSWORD=ton_mot_de_passe_ici
# Sur Render : utilise DATABASE_URL à la place (fourni automatiquement)
DATABASE_URL=

# Sécurité JWT — chaîne aléatoire longue (minimum 32 caractères)
JWT_SECRET=remplace_par_un_secret_tres_long_et_aleatoire

# Mot de passe admin pour /admin
ADMIN_PASSWORD=ton_mot_de_passe_admin

# Email — notifications de commandes
EMAIL_SERVICE=gmail
EMAIL_USER=nabousene2002@gmail.com
EMAIL_PASS=mot_de_passe_application_gmail_16_caracteres
ADMIN_EMAIL=nabousene2002@gmail.com

# URL du frontend (sans slash à la fin)
FRONTEND_URL=https://ton-username.github.io

# Port (Render le gère automatiquement)
PORT=5000
